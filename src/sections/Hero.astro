---
---

<section class="relative min-h-[92vh] flex flex-col items-center justify-center text-center px-4 py-24 overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(245,158,11,0.08)_0%,transparent_70%)] pointer-events-none"></div>

  <span data-reveal="left" data-delay="0" class="inline-block text-[#dc2626] text-xs font-bold tracking-[0.2em] uppercase mb-5 px-4 py-1.5 rounded-full border border-[#dc2626]/30 bg-[#dc2626]/5">
    Spolehliví od roku 1998
  </span>

  <h1 data-reveal="left" data-delay="150" class="text-5xl md:text-7xl font-black leading-[1.05] mb-6 max-w-3xl">
    Váš spolehlivý<br />
    <span class="text-[#dc2626]">Autoservis</span><br />
    Tým odborníků
  </h1>

  <p data-reveal="left" data-delay="300" class="text-gray-400 text-lg md:text-xl max-w-lg mb-10 leading-relaxed">
    Od výměny oleje po generální opravu motoru — rychlý a poctivý servis, který vás udrží na silnici.
  </p>

  <div data-reveal="left" data-delay="450" class="flex flex-col sm:flex-row gap-4 w-full max-w-sm sm:max-w-none sm:w-auto">
    <a href="#contact" class="bg-[#dc2626] text-black font-bold px-8 py-4 rounded-full hover:bg-red-500 transition-colors text-base">
      Objednat servis
    </a>
    <a href="#services" class="border border-white/20 text-white font-semibold px-8 py-4 rounded-full hover:border-[#dc2626]/60 hover:text-[#dc2626] transition-colors text-base">
      Naše služby
    </a>
  </div>

  <!-- Scroll hint -->
  <div data-reveal="up" data-delay="600" class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-gray-600 text-xs">
    <span>Posunout</span>
    <div class="w-px h-8 bg-linear-to-b from-gray-600 to-transparent"></div>
  </div>
</section>
